---
import { getDictionary, getLocale, type Locale } from "../../i18n/translations";

interface Props {
  locale?: Locale;
}

const { locale: localeProp } = Astro.props;
const locale = getLocale(localeProp ?? Astro.currentLocale);
const t = getDictionary(locale);
---

<section
  id="about"
  data-section
  class="section-panel space-y-3 mt-6 animate-slide-in"
>
  <div class="space-y-6">
    {/* Post-style card */}
    <article class="border border-border bg-card p-6 space-y-4">
      <div class="flex items-center gap-3">
        <div class="w-2 h-2 bg-primary rotate-45"></div>
        <span
          class="font-mono text-xs uppercase tracking-widest text-muted-foreground"
          >{t.about.publishedAgo}</span
        >
      </div>
      <h2 class="text-3xl font-bold leading-tight">
        {t.about.headingPrefix}<br />
        <span class="text-primary italic"> {t.about.headingHighlight} </span>
      </h2>
      <div class="h-px line-decorative"></div>
      <p class="text-muted-foreground leading-relaxed">
        {t.about.description}
      </p>
    </article>

    {/* Philosophy quote */}
    <article class="border-l-2 border-primary pl-6 py-4">
      <blockquote class="text-lg italic text-foreground leading-relaxed">
        {t.about.phrase}
      </blockquote>
      <p class="mt-2 font-mono text-xs text-muted-foreground">
        — {t.about.philosophy}
      </p>
    </article>
  </div>
</section>
