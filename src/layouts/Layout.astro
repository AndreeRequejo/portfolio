---
import "../styles/global.css";
import "@fontsource-variable/jetbrains-mono";
import "@fontsource-variable/playfair-display";
import "@fontsource-variable/dm-sans";

import ProfileSidebar from "../components/ProfileSidebar.astro";
import MobileHeader from "../components/MobileHeader.astro";
import FeedNav from "../components/FeedNav.astro";

const tabs = [
  {
    id: "about",
    label: "Sobre mi",
    iconPath:
      '<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>',
  },
  {
    id: "projects",
    label: "Proyectos",
    iconPath:
      '<path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"/><path d="M8 10v4"/><path d="M12 10v2"/><path d="M16 10v6"/>',
  },
  {
    id: "skills",
    label: "Skills",
    iconPath:
      '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  },
  {
    id: "experience",
    label: "Experiencia",
    iconPath:
      '<rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>',
  },
  {
    id: "contact",
    label: "Contacto",
    iconPath: '<path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/>',
  },
];

const yearNow = new Date().getFullYear();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Andree Requejo - Developer</title>
  </head>
  <body class="min-h-screen bg-background flex flex-col lg:flex-row">
    <ProfileSidebar />
    <MobileHeader />
    <main class="flex-1 min-w-0 pb-16 sm:pb-0">
      <FeedNav tabs={tabs} />
      <div class="max-w-2xl mx-auto p-4 sm:p-6">
        <div class="h-8 geometric-lines mb-4 opacity-40"></div>
        <slot />
        <footer class="mt-12 pb-8 text-center">
          <div class="h-px line-decorative mb-4"></div>
          <p
            class="font-mono text-[10px] uppercase tracking-widest text-muted-foreground"
          >
            © {yearNow} · Hecho con ♥ y mucho código
          </p>
        </footer>
      </div>
    </main>
  </body>
</html>
